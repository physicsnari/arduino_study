p.28 서보모터- 스위치를 누를 때마다 30도씩 돌리는 코드
-----------------------------------------------------------
#include <Servo.h> //서보모터 라이브러리 사용

int sw = 8;  // 스위치 8핀에 연결
int servoPin = 9; // 서보모터 신호 9핀에 연결

Servo myServo;

int angle = 0;

// 버튼 상태 저장용
int lastButtonState = HIGH;
int currentButtonState = HIGH;

void setup()
{
  pinMode(sw, INPUT_PULLUP);   // 버튼 한쪽이 GND에 연결된 구조
  myServo.attach(servoPin);
  myServo.write(angle);
}

void loop()
{
  currentButtonState = digitalRead(sw);

  // 버튼이 눌린 순간 감지: HIGH -> LOW
  if (lastButtonState == HIGH && currentButtonState == LOW)
  {
    angle = angle + 30;

    if (angle > 180)
    {
      angle = 0;
    }

    myServo.write(angle);

    delay(200);  // 간단한 디바운싱
  }

  lastButtonState = currentButtonState;
}
