p.22 택트 스위치로 켜고 끄기 실습
-----------------------------------------------------------
int sw = 8; //스위치 디지털 핀 8에 연결
int led = 7; //LED 디지털 핀 7에 연결

void setup()
{
  pinMode(sw, INPUT_PULLUP);   //디지털 핀 8 입력으로 설정
  pinMode(led, OUTPUT);    //디지털 핀 7 출력으로 설정
}

void loop()
{
  if(digitalRead(sw) == LOW)  // 스위치 버튼 누르면 LOW
  {
    digitalWrite(led, HIGH);  // LED 켜짐
  }
  else
  {
    digitalWrite(led, LOW);   // LED 꺼짐
  }
  delay(100); // 100ms마다 계속해서 스위치 신호 들어오는지 여부 점검
}

